# ============================================================
# Annyzbeauty - Apache Configuration
# Compatible with InfinityFree hosting
# ============================================================

Options -Indexes

# ---- PHP Settings (InfinityFree compatible) ----
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>

# ---- Protect sensitive files ----
<FilesMatch "\.(sql|log|env|ini|cfg|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# ---- Protect includes directory ----
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^database/ - [F,L]

    # Force HTTPS (uncomment on live server)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ---- Cache static assets ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg  "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
